{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "char_filter": {
        "arabic_normalizer": {
          "type": "mapping",
          "mappings": [
            "أ => ا",
            "إ => ا",
            "آ => ا",
            "ٱ => ا",
            "ى => ي",
            "ة => ه",
            "ۀ => ه"
          ]
        },
        "diacritics_remover": {
          "type": "mapping",
          "mappings": [
            "َ=>",
            "ُ=>",
            "ِ=>",
            "ً=>",
            "ٌ=>",
            "ٍ=>",
            "ّ=>",
            "ْ=>",
            "ٰ=>",
            "ۡ=>"
          ]
        }
      },
      "filter": {
        "arabic_stop": {
          "type": "stop",
          "stopwords_path": "stopwords_ar.txt"
        },
        "arabic_stemmer": {
          "type": "stemmer",
          "language": "arabic"
        },
        "arabic_synonyms": {
          "type": "synonym",
          "synonyms_path": "synonyms.txt"
        },
        "arabic_synonyms_graph": {
          "type": "synonym_graph",
          "synonyms_path": "synonyms.txt"
        },
        "word_delimiter": {
          "type": "word_delimiter",
          "split_on_numerics": false,
          "preserve_original": true
        },
        "unique_filter": {
          "type": "unique"
        }
      },
      "tokenizer": {
        "arabic_tokenizer": {
          "type": "pattern",
          "pattern": "\\s+",
          "lowercase": true
        },
        "ngram_tokenizer": {
          "type": "ngram",
          "min_gram": 2,
          "max_gram": 3,
          "token_chars": ["letter", "digit"]
        },
        "edge_ngram_tokenizer": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 10,
          "token_chars": ["letter"]
        }
      },
      "analyzer": {
        "arabic_analyzer": {
          "type": "custom",
          "char_filter": ["arabic_normalizer", "diacritics_remover"],
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "decimal_digit",
            "arabic_stop",
            "arabic_normalization",
            "arabic_stemmer",
            "arabic_synonyms"
          ]
        },
        "arabic_search_analyzer": {
          "type": "custom",
          "char_filter": ["arabic_normalizer", "diacritics_remover"],
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "decimal_digit",
            "arabic_stop",
            "arabic_normalization",
            "arabic_stemmer",
            "arabic_synonyms_graph"
          ]
        },
        "arabic_exact_analyzer": {
          "type": "custom",
          "char_filter": ["diacritics_remover"],
          "tokenizer": "standard",
          "filter": ["lowercase"]
        },
        "autocomplete_analyzer": {
          "type": "custom",
          "tokenizer": "edge_ngram_tokenizer",
          "filter": ["lowercase", "arabic_normalization"]
        },
        "autocomplete_search_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "arabic_normalization"]
        },
        "ngram_analyzer": {
          "type": "custom",
          "tokenizer": "ngram_tokenizer",
          "filter": ["lowercase"]
        }
      },
      "normalizer": {
        "arabic_normalizer": {
          "type": "custom",
          "char_filter": ["arabic_normalizer", "diacritics_remover"],
          "filter": ["lowercase"]
        }
      }
    }
  }
}
