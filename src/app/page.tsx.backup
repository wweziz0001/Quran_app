// API Section
function ApiSection() {
  const endpoints = [
    { method: 'GET', path: '/api/surahs', description: 'List all surahs' },
    { method: 'GET', path: '/api/surahs/:id', description: 'Get surah with ayahs' },
    { method: 'GET', path: '/api/ayah/:id', description: 'Get single ayah' },
    { method: 'GET', path: '/api/reciters', description: 'List all reciters' },
    { method: 'POST', path: '/api/auth/login', description: 'User login' },
    { method: 'POST', path: '/api/auth/register', description: 'User registration' },
    { method: 'GET', path: '/api/bookmarks', description: 'Get user bookmarks' },
    { method: 'POST', path: '/api/bookmarks', description: 'Add bookmark' },
    { method: 'GET', path: '/api/search', description: 'Search Quran' },
    { method: 'GET', path: '/api/admin/users', description: 'List users (admin)' },
  ];

  const exampleRequest = `GET /api/surahs/1?translation=en-sahih

Headers:
  Accept: application/json`;

  const exampleResponse = `{
  "success": true,
  "data": {
    "id": 1,
    "number": 1,
    "nameArabic": "الفاتحة",
    "nameEnglish": "Al-Fatiha",
    "totalAyahs": 7,
    "ayahs": [
      {
        "id": 1,
        "ayahNumber": 1,
        "textArabic": "بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ",
        "translation": {
          "text": "In the name of Allah, the Most Gracious...",
          "sourceName": "Sahih International"
        }
      }
    ]
  }
}`;

  return (
    <div className="space-y-6">
      <div>
        <h2 className="text-3xl font-bold">API Documentation</h2>
        <p className="text-muted-foreground">REST API endpoints with request/response examples</p>
      </div>

      {/* Endpoints List */}
      <div className="space-y-3">
        {endpoints.map((ep, i) => (
          <Card key={i} className="overflow-hidden">
            <div className="flex items-center p-4 gap-4">
              <Badge className={cn(
                "font-mono text-xs",
                ep.method === 'GET' && "bg-green-500/10 text-green-600 border-green-500/20",
                ep.method === 'POST' && "bg-blue-500/10 text-blue-600 border-blue-500/20"
              )}>
                {ep.method}
              </Badge>
              <code className="font-mono text-sm">{ep.path}</code>
              <span className="text-sm text-muted-foreground ml-auto">{ep.description}</span>
            </div>
          </Card>
        ))}
      </div>

      {/* Example */}
      <Card>
        <CardHeader>
          <CardTitle>Example: Get Surah</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
          <div>
            <p className="text-sm font-medium mb-2">Request</p>
            <CodeBlock code={exampleRequest} />
          </div>
          <div>
            <p className="text-sm font-medium mb-2">Response</p>
            <CodeBlock code={exampleResponse} />
          </div>
        </CardContent>
      </Card>
    </div>
  );
}

