    ],
    indexes: ['idx_ayah_number_global', 'idx_page_number', 'idx_juz_number', 'unique_surah_ayah'],
    foreignKeys: [
      { columns: ['surah_id'], references: 'surahs(id) ON DELETE CASCADE' }
    ]
  },
  {
    name: 'reciters',
    description: 'Audio reciters profile',
    rowCount: 5,
    columns: [
      { name: 'id', type: 'VARCHAR(30)', nullable: false, primary: true, unique: true },
      { name: 'name_arabic', type: 'VARCHAR(255)', nullable: false, primary: false, unique: false },
      { name: 'name_english', type: 'VARCHAR(255)', nullable: false, primary: false, unique: false },
      { name: 'slug', type: 'VARCHAR(255)', nullable: false, primary: false, unique: true },
