      { name: 'avatar_url', type: 'VARCHAR(500)', nullable: true, primary: false, unique: false },
      { name: 'locale', type: 'VARCHAR(10)', nullable: false, primary: false, unique: false, default: 'en' },
      { name: 'theme', type: 'VARCHAR(20)', nullable: false, primary: false, unique: false, default: 'system' },
      { name: 'is_active', type: 'BOOLEAN', nullable: false, primary: false, unique: false, default: 'true' },
      { name: 'created_at', type: 'TIMESTAMP', nullable: false, primary: false, unique: false, default: 'NOW()' },
      { name: 'updated_at', type: 'TIMESTAMP', nullable: false, primary: false, unique: false },
      { name: 'last_login_at', type: 'TIMESTAMP', nullable: true, primary: false, unique: false },
    ],
    indexes: ['idx_email', 'idx_role'],
    foreignKeys: []
  },
  {
