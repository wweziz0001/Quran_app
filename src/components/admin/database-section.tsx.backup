'use client';

import { useState } from 'react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Collapsible, CollapsibleContent, CollapsibleTrigger } from '@/components/ui/collapsible';
import { Database, ChevronDown, Copy, Check, Key, List, Link2 } from 'lucide-react';
import { cn } from '@/lib/utils';

interface TableSchema {
  name: string;
  description: string;
  rowCount: number;
  columns: ColumnDef[];
  indexes: string[];
  foreignKeys: ForeignKeyDef[];
}

interface ColumnDef {
  name: string;
  type: string;
  nullable: boolean;
  primary: boolean;
  unique: boolean;
  default?: string;
}

interface ForeignKeyDef {
  columns: string[];
  references: string;
}

const tableSchemas: TableSchema[] = [
  {
    name: 'users',
    description: 'User accounts and authentication data',
    rowCount: 1250,
    columns: [
      { name: 'id', type: 'VARCHAR(30)', nullable: false, primary: true, unique: true },
      { name: 'email', type: 'VARCHAR(255)', nullable: false, primary: false, unique: true },
      { name: 'password_hash', type: 'VARCHAR(255)', nullable: false, primary: false, unique: false },
