      { name: 'name_arabic', type: 'VARCHAR(100)', nullable: false, primary: false, unique: false },
      { name: 'name_english', type: 'VARCHAR(100)', nullable: false, primary: false, unique: false },
      { name: 'name_transliteration', type: 'VARCHAR(100)', nullable: false, primary: false, unique: false },
      { name: 'revelation_type', type: 'VARCHAR(20)', nullable: false, primary: false, unique: false },
      { name: 'total_ayahs', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'page_number_start', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'juz_number_start', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'description', type: 'TEXT', nullable: true, primary: false, unique: false },
    ],
    indexes: ['idx_number', 'idx_revelation_type'],
    foreignKeys: []
  },
  {
    name: 'ayahs',
    description: 'Quran verses (6,236 records)',
    rowCount: 6236,
    columns: [
      { name: 'id', type: 'SERIAL', nullable: false, primary: true, unique: true },
      { name: 'surah_id', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'ayah_number', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'ayah_number_global', type: 'INT', nullable: false, primary: false, unique: false },
      { name: 'text_arabic', type: 'TEXT', nullable: false, primary: false, unique: false },
      { name: 'text_uthmani', type: 'TEXT', nullable: true, primary: false, unique: false },
